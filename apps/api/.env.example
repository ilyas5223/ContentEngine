# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLM (OpenRouter; free models walk a fallback list) ─────────────────────
OPENROUTER_API_KEY=
# Optional: override the default fallback model list (comma-separated).
# OPENROUTER_MODELS=

# ─── Stock footage ──────────────────────────────────────────────────────────
PEXELS_API_KEY=

# ─── TTS ────────────────────────────────────────────────────────────────────
# All optional. The worker walks: ElevenLabs → Kokoro → Piper → Google TTS,
# skipping any provider whose env vars aren't set. Google TTS is always
# available as the last-resort fallback so renders never hard-fail.

# ElevenLabs (paid; best quality). Voice mapping is per-template, hardcoded
# in apps/api/src/services/tts/elevenlabs.ts.
ELEVENLABS_API_KEY=

# Kokoro TTS (free, open-source). First run downloads ~325MB ONNX model;
# point KOKORO_MODEL_DIR at a persistent volume to avoid re-downloads on
# worker restart.
# KOKORO_MODEL_DIR=
# KOKORO_MODEL_ID=onnx-community/Kokoro-82M-v1.0-ONNX
# KOKORO_DTYPE=q8

# Piper TTS (free, open-source). Disabled unless both vars are set. Download
# a voice from https://github.com/rhasspy/piper/releases.
# PIPER_BIN=/usr/local/bin/piper
# PIPER_VOICE=/var/piper/voices/en_US-amy-medium.onnx

# ─── Redis (BullMQ) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Web ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
PORT=4000
